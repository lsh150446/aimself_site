---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";

const { title, description, pubDate, updatedDate } = Astro.props;

const headings = Astro.props.headings ?? []; // Astro 会在 Markdown 页面传入 headings
const hasToc = Array.isArray(headings) && headings.length > 0;
---

<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .grid {
        display: grid;
        grid-template-columns: 1fr 280px;
        gap: 22px;
        align-items: start;
      }

      .hero {
        padding: 56px 0 22px;
      }

      .hero h1 {
        margin: 0 0 12px;
        font-size: clamp(30px, 4.3vw, 48px);
        line-height: 1.12;
        letter-spacing: -0.04em;
      }

      .desc {
        margin: 0;
        opacity: .78;
        line-height: 1.75;
        max-width: 72ch;
        font-size: 16px;
      }

      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
        margin-top: 14px;
        opacity: .65;
        font-size: 13px;
      }

      .divider {
        height: 1px;
        background: rgba(0,0,0,.08);
        margin: 18px 0 0;
      }

      /* Article typography */
      article {
        padding: 22px 0 56px;
      }

      .prose {
        max-width: 74ch;
      }

      .prose :global(p) {
        line-height: 1.9;
        margin: 0 0 16px;
        opacity: .88;
      }

      .prose :global(h2) {
        margin: 34px 0 10px;
        font-size: 22px;
        letter-spacing: -0.02em;
      }

      .prose :global(h3) {
        margin: 24px 0 8px;
        font-size: 18px;
        letter-spacing: -0.02em;
      }

      .prose :global(a) {
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      .prose :global(ul),
      .prose :global(ol) {
        margin: 0 0 16px;
        padding-left: 20px;
        line-height: 1.9;
        opacity: .88;
      }

      .prose :global(blockquote) {
        margin: 18px 0;
        padding: 12px 14px;
        border-left: 3px solid rgba(0,0,0,.25);
        background: rgba(0,0,0,.03);
        border-radius: 10px;
        opacity: .9;
      }

      .prose :global(code) {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 0.92em;
        padding: 2px 6px;
        border: 1px solid rgba(0,0,0,.10);
        border-radius: 8px;
        background: rgba(0,0,0,.03);
      }

      .prose :global(pre) {
        overflow: auto;
        padding: 14px;
        border-radius: 14px;
        border: 1px solid rgba(0,0,0,.10);
        background: #0b0f19;
        color: #e7eefc;
        margin: 18px 0;
      }

      .prose :global(pre code) {
        border: none;
        background: transparent;
        padding: 0;
        color: inherit;
        font-size: 13px;
        line-height: 1.7;
      }

      .prose :global(hr) {
        border: 0;
        height: 1px;
        background: rgba(0,0,0,.08);
        margin: 26px 0;
      }

      /* TOC */
      .toc {
        position: sticky;
        top: 18px;
        border: 1px solid rgba(0,0,0,.10);
        border-radius: 16px;
        padding: 14px 14px 10px;
        background: rgba(255,255,255,.6);
      }

      .tocTitle {
        font-size: 13px;
        letter-spacing: .06em;
        text-transform: uppercase;
        opacity: .75;
        margin: 0 0 10px;
      }

      .toc :global(ol),
      .toc :global(ul) {
        margin: 0;
        padding-left: 16px;
        line-height: 1.8;
        font-size: 13px;
        opacity: .82;
      }

      .toc :global(a) {
        text-decoration: none;
      }

      .toc :global(a:hover) {
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      /* Mobile */
      @media (max-width: 960px) {
        .grid { grid-template-columns: 1fr; }
        .toc { display: none; }
        .hero { padding: 44px 0 18px; }
        article { padding: 18px 0 44px; }
      }
    </style>
  </head>

  <body>
    <Header />
    <main class="container">
      <section class="hero">
        <div class="grid">
          <div>
            <h1>{title}</h1>
            {description && <p class="desc">{description}</p>}
            <div class="meta">
              {pubDate && (
                <>
                  <span>发布：</span>
                  <FormattedDate date={pubDate} />
                </>
              )}
              {updatedDate && (
                <>
                  <span>·</span>
                  <span>更新：</span>
                  <FormattedDate date={updatedDate} />
                </>
              )}
            </div>
            <div class="divider"></div>
          </div>

          {hasToc && (
            <aside class="toc" aria-label="Table of contents">
              <p class="tocTitle">Contents</p>
              <nav>
                <ol>
                  {headings
                    .filter((h) => h.depth === 2 || h.depth === 3)
                    .map((h) => (
                      <li style={`margin-left:${h.depth === 3 ? "12px" : "0"}`}>
                        <a href={`#${h.slug}`}>{h.text}</a>
                      </li>
                    ))}
                </ol>
              </nav>
            </aside>
          )}
        </div>
      </section>

      <article>
        <div class="prose">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
